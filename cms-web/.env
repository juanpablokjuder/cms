# cms-web — Variables de entorno
# Copiar este archivo como .env.php o configurar en el servidor web.
# NUNCA commitear valores reales a git.
#
# En producción (Nginx/Apache), configurar mediante:
#   fastcgi_param  CMS_API_URL    "http://127.0.0.1:3000";
#   fastcgi_param  WEB_API_TOKEN  "tu_token_aqui";
# O en el pool PHP-FPM (/etc/php/8.3/fpm/pool.d/santelmo.conf):
#   env[CMS_API_URL]   = http://127.0.0.1:3000
#   env[WEB_API_TOKEN] = tu_token_aqui

# URL del CMS API (sin trailing slash)
CMS_API_URL=http://192.168.0.20:3000/api/v1

# Token estático para el módulo web
# Generar con: openssl rand -hex 32
WEB_API_TOKEN=cms_web_token_dev_replace_in_production_env32

# Configuración del sitio
SITE_NAME=Celulares Traika
SITE_TAGLINE=Celulares y tecnología en Argentina
SITE_URL=https://celularestraika.com
SITE_DESCRIPTION=Tu tienda de celulares y tecnología en Argentina. Los mejores precios, financiación y servicio técnico.
SITE_KEYWORDS=celulares, smartphones, Argentina, reparación, venta, iPhone, Samsung
SITE_PHONE=+54 11 XXXX-XXXX
SITE_EMAIL=info@celularestraika.com
