# cms-web-2 — Storefront (Celulares de alta gama)
# Copiar como .env y completar valores reales. NUNCA commitear el .env real.

# URL del CMS API (sin trailing slash)
CMS_API_URL=http://localhost:3000

# Token estático para autenticar contra /api/v1/web/*
# Generar con: openssl rand -hex 32
WEB_API_TOKEN=CAMBIAR_POR_TOKEN_REAL

# Configuración del sitio
SITE_NAME=Vértice Mobile
SITE_TAGLINE=Tecnología premium en Argentina
SITE_URL=https://verticemobile.com.ar
SITE_DESCRIPTION=Celulares de alta gama, tablets y accesorios premium en Argentina. Garantía oficial, financiación y servicio post-venta.
SITE_KEYWORDS=celulares premium, iPhone, Samsung Galaxy, alta gama, Argentina, tienda

SITE_PHONE=+54 11 0000-0000
SITE_EMAIL=hola@verticemobile.com.ar
SITE_WHATSAPP=541100000000
SITE_INSTAGRAM=verticemobile
