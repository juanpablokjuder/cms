Options -Indexes
ServerSignature Off

# ── Security headers ──────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: http:; connect-src 'self';"
</IfModule>

# ── Block sensitive files ─────────────────────────────────
<FilesMatch "(\.env|\.env\..*|composer\.json|composer\.lock|package\.json|\.git)">
  Order allow,deny
  Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct access to private folders
  RewriteRule ^(config|lib|pages|components)/  - [F,L]

  # Static assets passthrough
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route everything else through index.php
  RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# ── Cache estáticos ──────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css              "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
</IfModule>

# ── Compresión gzip ──────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

AddDefaultCharset UTF-8
