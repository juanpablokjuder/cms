{
  "name": "cms-api",
  "version": "1.0.0",
  "description": "CMS RESTful API — Node.js 22 LTS · Fastify v5 · MariaDB",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/database/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.1.0",
    "mariadb": "^3.3.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
