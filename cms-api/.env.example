NODE_ENV=development
PORT=3000
HOST=192.168.0.20

# ── MariaDB ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3308
DB_NAME=db-cms
DB_USER=root
DB_PASSWORD=root123
DB_CONNECTION_LIMIT=10

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_very_long_random_secret_key_minimum_32_chars
JWT_EXPIRES_IN=15m

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1

# URL pública de la API (sin barra final). Usada para construir URLs absolutas de archivos.
PUBLIC_API_URL=http://localhost:3000
